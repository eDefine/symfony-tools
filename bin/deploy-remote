#!/usr/bin/env bash

set -euo pipefail
#cd "${0%/*}/.." || exit

deploy_steps=7
no_color='\033[0m'
label_color='\033[1;36m'
warning_color='\033[1;33m'

function usage() {
  echo "Usage:"
  echo "  $0 user@host directory"
}

if [[ ! -v 2 ]]; then
  usage
  exit 1
fi

user_and_host="$1"
directory="$2"

branch="master"
if [[ -v 3 ]]; then
  branch="$3"
fi

function step_label() {
  echo -e "$label_color$1/$deploy_steps $2$no_color"
}

function server_command() {
  ssh -t -o LogLevel=QUIET "${user_and_host}" "cd \"$directory\" && $1" | sed "s/^/    /g"
  echo ""
}

echo -e "${warning_color}You are about to deploy branch ${branch} to production. Type 'deploy ${branch}' to proceed.${no_color}"
read -r answer

if [ "$answer" != "deploy ${branch}" ]; then
  exit 1
fi

echo "Deploy started at $(date)"
echo ""
start_time=$(date +%s)

echo "Deploying branch ${branch}"

step_label 1 "Fetching changes"
server_command "git fetch --tags --prune"

step_label 2 "Changing branch"
server_command "git checkout ${branch}"

step_label 3 "Resetting branch"
server_command "git reset --hard origin/${branch} 2>/dev/null || git reset --hard ${branch}"

step_label 4 "Updating composer"
server_command "composer install --no-dev"

step_label 5 "Optimizing autoloader"
server_command "composer dump-autoload --no-dev --classmap-authoritative --optimize"

step_label 6 "Updating yarn"
server_command "yarn install"

step_label 7 "Rebuilding"
server_command "vendor/bin/rebuild --frontend --env prod"

end_time=$(date +%s)
echo "Finished in $((end_time-start_time)) seconds"
