#!/usr/bin/env bash

set -e
#cd "${0%/*}/.." || exit

echo "Setup started at $(date)"
echo ""

function usage() {
  echo "Usage:"
  echo "  $0 directory..."
}

if [[ ! -v 1 ]]; then
  usage
  exit 1
fi

directories="$@"

mkdir -p $directories

httpd_user=$(ps axo user,comm | grep -E '[a]pache|[h]ttpd|[_]www|[w]ww-data|[n]ginx' | grep -v root | head -1 | cut -d\  -f1)
sudo setfacl -dR -m u:"$httpd_user":rwX -m u:$(whoami):rwX $directories
sudo setfacl -R -m u:"$httpd_user":rwX -m u:$(whoami):rwX $directories
