#!/usr/bin/env bash

set -euo pipefail
#cd "${0%/*}/.." || exit

steps=6
no_color='\033[0m'
label_color='\033[1;36m'
warning_color='\033[1;33m'

function step_label() {
  echo -e "$label_color$1/$steps $2$no_color"
}

function local_command() {
  $1 | sed "s/^/    /g"
  echo ""
}

function usage() {
  echo "Usage:"
  echo "  $0 [options]"
  echo ""
  echo "Rebuild Options:"
  echo "  -e|--env ENV  Run rebuild for given environment (default: dev)"
  echo "  -f|--frontend Rebuilds frontend"
  echo ""
  echo "Miscellaneous Options:"
  echo "  -u|--usage    Output this message"
}

env='dev'
frontend=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--env)
      shift
      env="$1"
      shift
      ;;
    -f|--frontend)
      frontend=true
      shift
      ;;
    -u|--usage)
      usage
      exit 0
      ;;
    *)
      usage
      exit 1
      ;;
  esac
done

echo "Rebuild ($env) started at $(date)"
echo ""
start_time=$(date +%s)

step_label 1 "Dropping schema"
local_command "php bin/console doctrine:schema:drop --ansi --env $env --full-database --force"

step_label 2 "Creating schema"
local_command "php bin/console doctrine:schema:create --ansi --env $env"

step_label 3 "Loading fixtures"
if [ "$env" != "test" ]; then
  local_command "php bin/console doctrine:fixtures:load --ansi --env $env -n"
else
  echo -e "    ${warning_color}Skipped${no_color}"
  echo ""
fi

step_label 4 "Building frontend"
if [ "$frontend" = true ]; then
  if [ "$env" = "prod" ]; then
    local_command "yarn build"
  else
    local_command "yarn dev"
  fi
else
  echo -e "    ${warning_color}Skipped${no_color}"
  echo ""
fi

step_label 5 "Installing assets"
local_command "php bin/console assets:install --ansi --env $env"

step_label 6 "Clearing cache"
local_command "php bin/console cache:clear --ansi --env $env"

end_time=$(date +%s)
echo "Finished in $((end_time-start_time)) seconds"
