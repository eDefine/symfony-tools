#!/usr/bin/env bash

set -euo pipefail
cd "${0%/*}/.." || exit

config_file="symfony-tools.ini"
if [[ ! -e "$config_file" ]]; then
  echo "Config file $config_file does not exist"
  exit 1
fi

source "$config_file"

if [[ -z "$DEPLOY_LOCAL_USER" ]]; then
  echo "DEPLOY_LOCAL_USER is not set in $config_file"
  exit 1
fi

if [[ -z "$DEPLOY_LOCAL_DIR" ]]; then
  echo "DEPLOY_LOCAL_DIR is not set in $config_file"
  exit 1
fi

deploy_steps=7
no_color='\033[0m'
label_color='\033[1;36m'
warning_color='\033[1;33m'

function step_label() {
  echo -e "$label_color$1/$deploy_steps $2$no_color"
}

function command() {
  sudo -u "$DEPLOY_LOCAL_USER" sh -c "cd $DEPLOY_LOCAL_DIR && $1" | sed "s/^/    /g"
  echo ""
}

echo "Deploy started at $(date)"
echo ""
start_time=$(date +%s)

echo "Deploying branch ${branch}"

branch="master"
if [[ -v 1 ]]; then
  branch="$1"
fi

step_label 1 "Fetching changes"
command "git fetch"

step_label 2 "Changing branch"
command "git checkout ${branch}"

step_label 3 "Resetting branch"
command "git reset --hard ${branch}"

step_label 4 "Updating composer"
command "composer install --no-dev"

step_label 5 "Optimizing autoloader"
command "composer dump-autoload --no-dev --classmap-authoritative --optimize"

step_label 6 "Updating yarn"
command "yarn install"

step_label 7 "Rebuilding"
command "vendor/bin/rebuild --frontend --env prod"

end_time=$(date +%s)
echo "Finished in $((end_time-start_time)) seconds"
