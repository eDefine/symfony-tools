#!/usr/bin/env bash

set -euo pipefail
#cd "${0%/*}/.." || exit

deploy_steps=7
no_color='\033[0m'
label_color='\033[1;36m'

function usage() {
  echo "Usage:"
  echo "  $0 user directory [branch or tag]"
}

if [[ ! -v 2 ]]; then
  usage
  exit 1
fi

user="$1"
directory="$2"

branch="master"
if [[ -v 3 ]]; then
  branch="$3"
fi

function step_label() {
  echo -e "$label_color$1/$deploy_steps $2$no_color"
}

function local_command() {
  sudo -u "$user" sh -c "cd \"$directory\" && $1" | sed "s/^/    /g"
  echo ""
}

echo "Deploy started at $(date)"
echo ""
start_time=$(date +%s)

echo "Deploying branch ${branch}"

step_label 1 "Fetching changes"
local_command "git fetch --tags --prune"

step_label 2 "Changing branch"
local_command "git checkout ${branch}"

step_label 3 "Resetting branch"
local_command "git reset --hard origin/${branch} 2>/dev/null || git reset --hard ${branch}"

step_label 4 "Updating composer"
local_command "composer install --no-dev"

step_label 5 "Optimizing autoloader"
local_command "composer dump-autoload --no-dev --classmap-authoritative --optimize"

step_label 6 "Updating yarn"
local_command "yarn install"

step_label 7 "Rebuilding"
local_command "vendor/bin/rebuild --frontend --env prod"

end_time=$(date +%s)
echo "Finished in $((end_time-start_time)) seconds"
